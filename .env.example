# ─────────────────────────────────────────────────────────────
#  Hosslimo – Environment Variables
#  Copy this file to .env and fill in the values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=production
PORT=3000

# Session (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
SESSION_SECRET=replace_with_a_long_random_string

# Admin credentials (used only on first boot to seed data/users.json)
# After first boot, change the password through the /admin dashboard.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe!2026

# SMTP — email notifications for contact form submissions
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@hosslimo.com
SMTP_PASSWORD=your_smtp_password

# Email address that receives contact form notifications
CONTACT_RECEIVER_EMAIL=office@hosslimo.com

# Google reCAPTCHA v3
# Register at https://www.google.com/recaptcha/admin
# Site key is public (embedded in the frontend).
# Secret key stays server-side only.
RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_v3_secret_key
